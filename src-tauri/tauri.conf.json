{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AQWDex",
  "version": "0.1.0",
  "identifier": "com.aqwdex.dev",
  "build": {
    "frontendDist": "./main/dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "cd main && trunk serve",
    "beforeBuildCommand": "cd main && trunk build"
  },
  "app": {
    "windows": [
      {
        "title": "AQWDex",
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
